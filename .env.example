LLM_API_KEY=your-llm-api-key
ENHANCER_API_KEY=your-enhancer-api-key
# API access key for FastAPI. Leave empty to disable authentication.
RAG_API_KEY=
# Optional per-user API keys. Supports user:key pairs separated by comma/newline,
# or a JSON object. When set, it takes precedence over RAG_API_KEY and scopes
# session history by authenticated user.
RAG_API_KEYS=
